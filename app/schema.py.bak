from pydantic import BaseModel, Field
from typing import List, Optional

class Inventory(BaseModel):
    stock_level: int
    location: Optional[str] = None

class Sales(BaseModel):
    velocity: Optional[str] = None  # e.g., "High", "Low"
    reasoning: Optional[str] = None

class Product(BaseModel):
    sku: str
    name: str
    brand: Optional[str] = None
    cost: Optional[float] = None
    retail_price: Optional[float] = None
    short_description: Optional[str] = None
    long_description: Optional[str] = None
    image_uri: Optional[str] = None
    inventory: Optional[Inventory] = None
    sales: Optional[Sales] = None

class CatalogSpecs(BaseModel):
    sku: str
    specs: str
    image_urls: List[str]

class TrendAnalysis(BaseModel):
    trend_name: str
    executive_summary: str
    trend_start_date: Optional[str] = None
    trend_scope: Optional[str] = None
    trend_lifecycle_stage: Optional[str] = None
    primary_sources: List[str] = []
    taxonomy_attributes: "TaxonomyAttributes"
    search_vectors: List[str]

class Trend(BaseModel):
    name: str
    description: str
    match_score: float
    reasoning: str

class ProductTrendMapping(BaseModel):
    micro_trends: List[Trend]
    macro_trends: List[Trend]

class TaxonomyAttributes(BaseModel):
    primary_aesthetic: str
    secondary_aesthetic: str
    key_garments: List[str]
    materials_and_textures: List[str]
    color_palette: List[str]
    mood_keywords: List[str]
    target_occasion: List[str]
    seasonality: str

class TrendSpotterOutput(BaseModel):
    executive_summary: str
    trend_name: str
    taxonomy_attributes: TaxonomyAttributes
    search_vectors: List[str]

class CampaignDraft(BaseModel):
    campaign_name: str
    trend: str
    target_audience: str
    keyframes: List[str]
    video_url: Optional[str] = None
